<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Snake Game</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 100%);
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 25px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
            padding: 25px;
            text-align: center;
        }

        body.dark-mode .container {
            background: rgba(30, 30, 50, 0.95);
            color: white;
        }

        h1 {
            color: #2a5298;
            margin-bottom: 10px;
        }

        .game-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
            padding: 10px 20px;
            background: #f0f0f0;
            border-radius: 15px;
        }

        body.dark-mode .game-info {
            background: #3d3d55;
        }

        .score, .high-score {
            font-size: 20px;
            font-weight: bold;
        }

        canvas {
            border: 3px solid #2a5298;
            border-radius: 10px;
            background: #111;
            margin-bottom: 15px;
        }

        .controls {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 15px;
        }

        button {
            background: #2a5298;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
        }

        button:hover {
            background: #1e3c72;
        }

        .dark-toggle {
            background: #667eea;
            margin-bottom: 10px;
        }

        .direction-buttons {
            display: grid;
            grid-template-columns: repeat(3, 60px);
            gap: 8px;
            justify-content: center;
            margin-top: 10px;
        }

        .dir-btn {
            padding: 10px;
            font-size: 20px;
            background: #2a5298;
        }

        .game-over {
            color: #ff6b6b;
            font-weight: bold;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <button class="dark-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
        <h1>🐍 Snake Game</h1>
        <div class="game-info">
            <div class="score">Score: <span id="score">0</span></div>
            <div class="high-score">High Score: <span id="highScore">0</span></div>
        </div>
        <canvas id="gameCanvas" width="400" height="400"></canvas>
        <div class="controls">
            <button onclick="resetGame()">🔄 New Game</button>
            <button onclick="togglePause()">⏸️ Pause</button>
        </div>
        <div class="direction-buttons">
            <div></div>
            <button class="dir-btn" onclick="changeDirection('UP')">⬆️</button>
            <div></div>
            <button class="dir-btn" onclick="changeDirection('LEFT')">⬅️</button>
            <button class="dir-btn" onclick="changeDirection('DOWN')">⬇️</button>
            <button class="dir-btn" onclick="changeDirection('RIGHT')">➡️</button>
        </div>
        <div id="gameOverMsg" class="game-over"></div>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const gridSize = 20;
        const tileCount = canvas.width / gridSize;

        let snake = [{x: 10, y: 10}];
        let direction = {x: 0, y: 0};
        let food = {};
        let score = 0;
        let highScore = localStorage.getItem('snakeHighScore') || 0;
        let gameRunning = true;
        let paused = false;

        document.getElementById('highScore').textContent = highScore;

        function randomFood() {
            food = {
                x: Math.floor(Math.random() * tileCount),
                y: Math.floor(Math.random() * tileCount)
            };
            // Check if food spawns on snake
            for (let segment of snake) {
                if (segment.x === food.x && segment.y === food.y) {
                    randomFood();
                }
            }
        }

        function draw() {
            // Clear canvas
            ctx.fillStyle = '#111';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Draw snake
            ctx.fillStyle = '#4caf50';
            for (let i = 0; i < snake.length; i++) {
                ctx.fillRect(snake[i].x * gridSize, snake[i].y * gridSize, gridSize - 2, gridSize - 2);
            }

            // Draw food
            ctx.fillStyle = '#ff6b6b';
            ctx.fillRect(food.x * gridSize, food.y * gridSize, gridSize - 2, gridSize - 2);
        }

        function update() {
            if (!gameRunning || paused) return;

            const head = {x: snake[0].x + direction.x, y: snake[0].y + direction.y};

            // Wall collision
            if (head.x < 0 || head.x >= tileCount || head.y < 0 || head.y >= tileCount) {
                gameOver();
                return;
            }

            // Self collision
            for (let segment of snake) {
                if (head.x === segment.x && head.y === segment.y) {
                    gameOver();
                    return;
                }
            }

            snake.unshift(head);

            // Food collision
            if (head.x === food.x && head.y === food.y) {
                score++;
                document.getElementById('score').textContent = score;
                randomFood();
            } else {
                snake.pop();
            }
        }

        function gameOver() {
            gameRunning = false;
            document.getElementById('gameOverMsg').textContent = '💀 Game Over! Press "New Game" to play again 💀';
            if (score > highScore) {
                highScore = score;
                localStorage.setItem('snakeHighScore', highScore);
                document.getElementById('highScore').textContent = highScore;
            }
        }

        function resetGame() {
            snake = [{x: 10, y: 10}];
            direction = {x: 0, y: 0};
            score = 0;
            gameRunning = true;
            paused = false;
            document.getElementById('score').textContent = score;
            document.getElementById('gameOverMsg').textContent = '';
            randomFood();
            draw();
        }

        function togglePause() {
            if (!gameRunning) return;
            paused = !paused;
        }

        function changeDirection(newDir) {
            if (!gameRunning || paused) return;
            const keyMap = {
                'UP': {x: 0, y: -1},
                'DOWN': {x: 0, y: 1},
                'LEFT': {x: -1, y: 0},
                'RIGHT': {x: 1, y: 0}
            };
            const newDirection = keyMap[newDir];
            // Prevent 180-degree turns
            if ((direction.x === 0 && direction.y === 0) ||
                (newDirection.x !== -direction.x && newDirection.y !== -direction.y)) {
                direction = newDirection;
            }
        }

        function gameLoop() {
            update();
            draw();
            setTimeout(gameLoop, 100);
        }

        // Keyboard controls
        document.addEventListener('keydown', (e) => {
            const keyMap = {
                'ArrowUp': 'UP',
                'ArrowDown': 'DOWN',
                'ArrowLeft': 'LEFT',
                'ArrowRight': 'RIGHT'
            };
            if (keyMap[e.key]) {
                changeDirection(keyMap[e.key]);
                e.preventDefault();
            }
        });

        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            const btn = document.querySelector('.dark-toggle');
            btn.textContent = document.body.classList.contains('dark-mode') ? '☀️ Light Mode' : '🌙 Dark Mode';
        }

        randomFood();
        gameLoop();
    </script>
</body>
</html>
