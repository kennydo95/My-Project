<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>To-do</title>
  <style>
    :root {
      --bg: #fafaf9;
      --card: #ffffff;
      --border: #e7e5e4;
      --border-hover: #d6d3d1;
      --text: #1c1917;
      --text-muted: #78716c;
      --text-dim: #a8a29e;
      --accent: #1c1917;
      --accent-text: #fafaf9;
      --danger: #e11d48;
      --danger-bg: #fff1f2;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #0c0a09;
        --card: #1c1917;
        --border: #292524;
        --border-hover: #44403c;
        --text: #f5f5f4;
        --text-muted: #a8a29e;
        --text-dim: #78716c;
        --accent: #f5f5f4;
        --accent-text: #1c1917;
        --danger: #fb7185;
        --danger-bg: rgba(225, 29, 72, 0.15);
      }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 3rem 1rem;
      line-height: 1.5;
    }
    .container { max-width: 28rem; margin: 0 auto; }
    h1 {
      font-size: 24px;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }
    .add-row { display: flex; gap: 8px; margin-bottom: 1rem; }
    input[type="text"] {
      flex: 1;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
      color: var(--text);
      font-size: 15px;
      font-family: inherit;
      outline: none;
      transition: border-color 0.15s;
    }
    input[type="text"]:focus { border-color: var(--border-hover); }
    input[type="text"]::placeholder { color: var(--text-dim); }
    .btn-add {
      width: 40px;
      height: 40px;
      background: var(--accent);
      color: var(--accent-text);
      border: none;
      border-radius: 8px;
      font-size: 18px;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.05s;
    }
    .btn-add:hover { opacity: 0.9; }
    .btn-add:active { transform: scale(0.95); }
    .btn-add:disabled { opacity: 0.3; cursor: not-allowed; }
    .list { display: flex; flex-direction: column; gap: 6px; }
    .empty {
      text-align: center;
      color: var(--text-dim);
      font-size: 14px;
      padding: 2rem 0;
    }
    .todo {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 12px;
    }
    .check {
      width: 20px;
      height: 20px;
      border: 2px solid var(--border-hover);
      border-radius: 5px;
      background: transparent;
      cursor: pointer;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.15s;
    }
    .check:hover { border-color: var(--text-muted); }
    .check.done {
      background: var(--accent);
      border-color: var(--accent);
    }
    .check.done::after {
      content: '';
      width: 6px;
      height: 10px;
      border-right: 2px solid var(--accent-text);
      border-bottom: 2px solid var(--accent-text);
      transform: rotate(45deg) translate(-1px, -1px);
    }
    .text {
      flex: 1;
      font-size: 15px;
      color: var(--text);
      word-break: break-word;
    }
    .text.done {
      text-decoration: line-through;
      color: var(--text-dim);
    }
    .btn-delete {
      width: 28px;
      height: 28px;
      background: transparent;
      border: none;
      color: var(--text-dim);
      cursor: pointer;
      border-radius: 6px;
      font-size: 16px;
      flex-shrink: 0;
      opacity: 0;
      transition: all 0.15s;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .todo:hover .btn-delete { opacity: 1; }
    .btn-delete:hover {
      color: var(--danger);
      background: var(--danger-bg);
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>To-do</h1>
    <div class="add-row">
      <input id="input" type="text" placeholder="Add a task…" autofocus />
      <button id="addBtn" class="btn-add" disabled>+</button>
    </div>
    <div id="list" class="list"></div>
  </div>

  <script>
    const input  = document.getElementById('input');
    const addBtn = document.getElementById('addBtn');
    const list   = document.getElementById('list');
    let todos = [];

    function render() {
      list.innerHTML = '';
      if (todos.length === 0) {
        list.innerHTML = '<p class="empty">Nothing here yet.</p>';
        return;
      }
      for (const todo of todos) {
        const row = document.createElement('div');
        row.className = 'todo';

        const check = document.createElement('button');
        check.className = 'check' + (todo.done ? ' done' : '');
        check.setAttribute('aria-label', todo.done ? 'Mark not done' : 'Mark done');
        check.onclick = () => { todo.done = !todo.done; render(); };

        const text = document.createElement('span');
        text.className = 'text' + (todo.done ? ' done' : '');
        text.textContent = todo.text;

        const del = document.createElement('button');
        del.className = 'btn-delete';
        del.innerHTML = '🗑';
        del.setAttribute('aria-label', 'Delete');
        del.onclick = () => {
          todos = todos.filter(t => t.id !== todo.id);
          render();
        };

        row.append(check, text, del);
        list.append(row);
      }
    }

    function addTodo() {
      const text = input.value.trim();
      if (!text) return;
      todos.unshift({ id: Date.now(), text, done: false });
      input.value = '';
      addBtn.disabled = true;
      render();
      input.focus();
    }

    input.addEventListener('input', () => {
      addBtn.disabled = !input.value.trim();
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') addTodo();
    });
    addBtn.addEventListener('click', addTodo);

    render();
  </script>
</body>
</html>
