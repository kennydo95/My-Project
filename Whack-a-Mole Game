<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whack-a-Mole!</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #2e8b57 0%, #228b22 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #1a1a2e 0%, #0f0c29 100%);
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 30px;
            padding: 25px;
            text-align: center;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

        body.dark-mode .container {
            background: rgba(30, 30, 50, 0.95);
            color: white;
        }

        h1 {
            color: #228b22;
            margin-bottom: 10px;
        }

        .stats {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
            padding: 15px;
            background: #f0f0f0;
            border-radius: 15px;
        }

        body.dark-mode .stats {
            background: #3d3d55;
        }

        .score, .time {
            font-size: 24px;
            font-weight: bold;
        }

        .score span, .time span {
            color: #228b22;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }

        .hole {
            aspect-ratio: 1;
            background: #8B4513;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.1s;
            box-shadow: inset 0 10px 15px rgba(0,0,0,0.3), 0 5px 10px rgba(0,0,0,0.2);
        }

        .hole.has-mole {
            background: #d2691e;
            cursor: pointer;
        }

        .mole {
            font-size: 50px;
            animation: popUp 0.2s ease;
        }

        @keyframes popUp {
            0% { transform: scale(0); }
            80% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }

        button {
            background: #228b22;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 16px;
            margin: 5px;
        }

        button:hover {
            background: #1e7a1e;
            transform: scale(1.02);
        }

        .dark-toggle {
            background: #667eea;
            margin-bottom: 15px;
        }

        .message {
            margin-top: 15px;
            font-size: 18px;
            font-weight: bold;
            color: #ff6b6b;
        }
    </style>
</head>
<body>
    <div class="container">
        <button class="dark-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
        <h1>🐭 Whack-a-Mole! 🔨</h1>
        <div class="stats">
            <div class="score">Score: <span id="score">0</span></div>
            <div class="time">Time: <span id="time">30</span>s</div>
        </div>
        <div class="grid" id="grid"></div>
        <div>
            <button onclick="startGame()">🎮 Start Game</button>
            <button onclick="resetGame()">🔄 Reset</button>
        </div>
        <div class="message" id="message">Click Start to play!</div>
    </div>

    <script>
        let score = 0;
        let timeLeft = 30;
        let gameActive = false;
        let timerInterval = null;
        let moleInterval = null;
        let currentMoleIndex = -1;

        const grid = document.getElementById('grid');
        const scoreDisplay = document.getElementById('score');
        const timeDisplay = document.getElementById('time');
        const messageDisplay = document.getElementById('message');

        function createGrid() {
            grid.innerHTML = '';
            for (let i = 0; i < 9; i++) {
                const hole = document.createElement('div');
                hole.className = 'hole';
                hole.dataset.index = i;
                hole.onclick = () => whack(i);
                grid.appendChild(hole);
            }
        }

        function showMole() {
            if (!gameActive) return;

            // Remove current mole
            if (currentMoleIndex !== -1) {
                const prevHole = grid.children[currentMoleIndex];
                prevHole.classList.remove('has-mole');
                prevHole.innerHTML = '';
            }

            // Show new mole at random hole
            const newIndex = Math.floor(Math.random() * 9);
            currentMoleIndex = newIndex;
            const newHole = grid.children[newIndex];
            newHole.classList.add('has-mole');
            newHole.innerHTML = '<div class="mole">🐭</div>';
        }

        function whack(index) {
            if (!gameActive) return;
            if (index === currentMoleIndex) {
                score++;
                scoreDisplay.textContent = score;
                
                // Hit effect
                const hole = grid.children[index];
                hole.innerHTML = '<div class="mole">💥</div>';
                setTimeout(() => {
                    if (hole.classList.contains('has-mole')) {
                        hole.innerHTML = '<div class="mole">🐭</div>';
                    }
                }, 100);
                
                // Remove mole immediately
                hole.classList.remove('has-mole');
                clearInterval(moleInterval);
                currentMoleIndex = -1;
                
                // Show new mole faster
                moleInterval = setInterval(showMole, Math.max(400, 1000 - Math.floor(score / 5) * 50));
                showMole();
            }
        }

        function startGame() {
            if (gameActive) return;
            
            resetGame();
            gameActive = true;
            messageDisplay.textContent = '🔨 Whack those moles! 🔨';
            
            timerInterval = setInterval(() => {
                if (timeLeft <= 1) {
                    endGame();
                } else {
                    timeLeft--;
                    timeDisplay.textContent = timeLeft;
                }
            }, 1000);
            
            moleInterval = setInterval(showMole, 800);
            showMole();
        }

        function endGame() {
            gameActive = false;
            clearInterval(timerInterval);
            clearInterval(moleInterval);
            
            if (currentMoleIndex !== -1) {
                const hole = grid.children[currentMoleIndex];
                hole.classList.remove('has-mole');
                hole.innerHTML = '';
            }
            
            let message = '';
            if (score >= 30) message = `🎉 Amazing! ${score} points! You're a pro! 🎉`;
            else if (score >= 20) message = `👏 Great job! ${score} points! 👏`;
            else if (score >= 10) message = `👍 Good work! ${score} points! Try again? 👍`;
            else message = `😅 ${score} points? You can do better! Try again! 😅`;
            
            messageDisplay.textContent = message;
        }

        function resetGame() {
            gameActive = false;
            clearInterval(timerInterval);
            clearInterval(moleInterval);
            
            score = 0;
            timeLeft = 30;
            currentMoleIndex = -1;
            
            scoreDisplay.textContent = score;
            timeDisplay.textContent = timeLeft;
            
            for (let i = 0; i < grid.children.length; i++) {
                grid.children[i].classList.remove('has-mole');
                grid.children[i].innerHTML = '';
            }
            
            messageDisplay.textContent = 'Click Start to play!';
        }

        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
            const btn = document.querySelector('.dark-toggle');
            btn.textContent = document.body.classList.contains('dark-mode') ? '☀️ Light Mode' : '🌙 Dark Mode';
        }

        createGrid();
    </script>
</body>
</html>
