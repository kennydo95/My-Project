<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>24 Game - Math Puzzle</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #f5af19 0%, #f12711 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 30px;
            padding: 30px;
            text-align: center;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

        body.dark-mode .container {
            background: rgba(30, 30, 50, 0.95);
            color: white;
        }

        h1 {
            color: #f12711;
            margin-bottom: 5px;
        }

        .subtitle {
            color: #888;
            margin-bottom: 20px;
        }

        .numbers {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
        }

        .number-card {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            font-weight: bold;
            color: white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        }

        .target {
            font-size: 48px;
            font-weight: bold;
            color: #f12711;
            margin-bottom: 20px;
        }

        .input-area {
            margin-bottom: 20px;
        }

        .equation-input {
            width: 100%;
            padding: 15px;
            font-size: 18px;
            font-family: monospace;
            border: 2px solid #667eea;
            border-radius: 15px;
            text-align: center;
            outline: none;
        }

        button {
            background: #f12711;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 16px;
            margin: 5px;
        }

        button:hover {
            background: #d41a08;
        }

        .check-btn {
            background: #4caf50;
        }

        .new-btn {
            background: #667eea;
        }

        .message {
            margin-top: 20px;
            padding: 15px;
            border-radius: 15px;
            font-weight: bold;
        }

        .message.correct {
            background: #4caf50;
            color: white;
        }

        .message.wrong {
            background: #ff6b6b;
            color: white;
        }

        .message.info {
            background: #f0f0f0;
            color: #333;
        }

        body.dark-mode .message.info {
            background: #3d3d55;
            color: white;
        }

        .solution {
            margin-top: 15px;
            font-size: 14px;
            color: #888;
        }

        .dark-toggle {
            background: #764ba2;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <button class="dark-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
        <h1>🎲 24 Game</h1>
        <div class="subtitle">Use +, -, ×, ÷ to make 24</div>

        <div class="numbers" id="numbers">
            <div class="number-card">?</div>
            <div class="number-card">?</div>
            <div class="number-card">?</div>
            <div class="number-card">?</div>
        </div>

        <div class="target">🎯 Target: 24</div>

        <div class="input-area">
            <input type="text" id="equation" class="equation-input" placeholder="Enter equation... (e.g., (6×8)÷(4-2))">
        </div>

        <div>
            <button class="check-btn" onclick="checkSolution()">✅ Check Answer</button>
            <button class="new-btn" onclick="newGame()">🎲 New Numbers</button>
            <button onclick="showSolution()">💡 Show Solution</button>
        </div>

        <div class="message info" id="message">Enter an equation using the 4 numbers to make 24!</div>
        <div class="solution" id="solution"></div>
    </div>

    <script>
        let currentNumbers = [];

        function generateNumbers() {
            const numbers = [];
            for (let i = 0; i < 4; i++) {
                numbers.push(Math.floor(Math.random() * 9) + 1);
            }
            return numbers;
        }

        function updateDisplay() {
            const numberDivs = document.querySelectorAll('.number-card');
            numberDivs.forEach((div, index) => {
                div.textContent = currentNumbers[index];
            });
        }

        function evaluateEquation(equation, numbers) {
            // Clean the equation
            let cleanEq = equation.replace(/×/g, '*').replace(/÷/g, '/');
            
            // Check if all numbers are used
            const numbersInEq = cleanEq.match(/\d+/g);
            if (!numbersInEq) return { valid: false, reason: 'No numbers found!' };
            
            // Convert to numbers and sort for comparison
            const usedNumbers = numbersInEq.map(Number).sort((a,b) => a-b);
            const givenNumbers = [...numbers].sort((a,b) => a-b);
            
            if (JSON.stringify(usedNumbers) !== JSON.stringify(givenNumbers)) {
                return { 
                    valid: false, 
                    reason: `Use exactly these numbers: ${numbers.join(', ')}` 
                };
            }
            
            // Evaluate
            try {
                const result = eval(cleanEq);
                if (Math.abs(result - 24) < 0.0001) {
                    return { valid: true, reason: 'Correct! 🎉' };
                } else {
                    return { valid: false, reason: `Result is ${result}, not 24!` };
                }
            } catch (e) {
                return { valid: false, reason: 'Invalid equation format!' };
            }
        }

        function checkSolution() {
            const equation = document.getElementById('equation').value;
            if (!equation.trim()) {
                showMessage('Please enter an equation!', 'info');
                return;
            }
            
            const result = evaluateEquation(equation, currentNumbers);
            
            if (result.valid) {
                showMessage('✅ ' + result.reason + ' Great job!', 'correct');
                document.getElementById('solution').innerHTML = '';
            } else {
                showMessage('❌ ' + result.reason, 'wrong');
            }
        }

        function showMessage(text, type) {
            const messageDiv = document.getElementById('message');
            messageDiv.textContent = text;
            messageDiv.className = `message ${type}`;
        }

        function newGame() {
            currentNumbers = generateNumbers();
            updateDisplay();
            document.getElementById('equation').value = '';
            showMessage('New numbers! Can you make 24?', 'info');
            document.getElementById('solution').innerHTML = '';
        }

        function solve24(numbers) {
            const ops = ['+', '-', '*', '/'];
            
            function applyOp(a, b, op) {
                if (op === '+') return a + b;
                if (op === '-') return a - b;
                if (op === '*') return a * b;
                if (op === '/') return b !== 0 ? a / b : null;
                return null;
            }
            
            function formatOp(a, b, op) {
                if (op === '+') return `(${a}+${b})`;
                if (op === '-') return `(${a}-${b})`;
                if (op === '*') return `(${a}×${b})`;
                if (op === '/') return `(${a}÷${b})`;
                return `(${a}${op}${b})`;
            }
            
            // Try all permutations
            function permute(arr) {
                if (arr.length === 1) return [arr];
                const result = [];
                for (let i = 0; i < arr.length; i++) {
                    const rest = [...arr.slice(0, i), ...arr.slice(i+1)];
                    const perms = permute(rest);
                    for (const perm of perms) {
                        result.push([arr[i], ...perm]);
                    }
                }
                return result;
            }
            
            const permutations = permute(numbers);
            
            for (const perm of permutations) {
                const [a,b,c,d] = perm;
                
                // Try different bracket patterns
                // Pattern 1: ((a op b) op c) op d
                for (const op1 of ops) {
                    for (const op2 of ops) {
                        for (const op3 of ops) {
                            const step1 = applyOp(a, b, op1);
                            if (step1 === null) continue;
                            const step2 = applyOp(step1, c, op2);
                            if (step2 === null) continue;
                            const step3 = applyOp(step2, d, op3);
                            if (step3 !== null && Math.abs(step3 - 24) < 0.0001) {
                                const expr = formatOp(formatOp(formatOp(a, b, op1), c, op2), d, op3);
                                return expr;
                            }
                        }
                    }
                }
                
                // Pattern 2: (a op b) op (c op d)
                for (const op1 of ops) {
                    for (const op2 of ops) {
                        for (const op3 of ops) {
                            const left = applyOp(a, b, op1);
                            const right = applyOp(c, d, op3);
                            if (left === null || right === null) continue;
                            const result = applyOp(left, right, op2);
                            if (result !== null && Math.abs(result - 24) < 0.0001) {
                                const expr = formatOp(formatOp(a, b, op1), formatOp(c, d, op3), op2);
                                return expr;
                            }
                        }
                    }
                }
            }
            
            return null;
        }

        function showSolution() {
            const solution = solve24(currentNumbers);
            if (solution) {
                document.getElementById('solution').innerHTML = `💡 Solution: ${solution} = 24`;
                showMessage('Here\'s one way to solve it!', 'info');
            } else {
                document.getElementById('solution').innerHTML = '😅 No solution found for these numbers. Try new numbers!';
                showMessage('These numbers might not have a solution. Generate new ones!', 'info');
            }
        }

        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
        }

        // Start a new game
        newGame();
    </script>
</body>
</html>
