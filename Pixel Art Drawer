<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pixel Art Drawer</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 30px;
            padding: 25px;
            text-align: center;
            max-width: 700px;
            width: 100%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

        body.dark-mode .container {
            background: rgba(30, 30, 50, 0.95);
            color: white;
        }

        h1 {
            color: #667eea;
            margin-bottom: 5px;
        }

        .subtitle {
            color: #888;
            margin-bottom: 20px;
        }

        .canvas-container {
            display: flex;
            justify-content: center;
            margin-bottom: 20px;
        }

        canvas {
            border: 3px solid #667eea;
            border-radius: 10px;
            cursor: crosshair;
            background: white;
        }

        .tools {
            display: flex;
            gap: 10px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .color-picker {
            width: 50px;
            height: 50px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            border: 2px solid #ddd;
        }

        .tool-btn {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 14px;
        }

        .tool-btn.active {
            background: #764ba2;
            box-shadow: 0 0 0 2px white, 0 0 0 4px #764ba2;
        }

        .tool-btn:hover {
            transform: scale(1.02);
        }

        .size-control {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f0f0f0;
            padding: 5px 15px;
            border-radius: 20px;
        }

        body.dark-mode .size-control {
            background: #3d3d55;
        }

        input[type="range"] {
            width: 100px;
        }

        button {
            background: #667eea;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
        }

        .dark-toggle {
            background: #764ba2;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>
    <div class="container">
        <button class="dark-toggle" onclick="toggleDarkMode()">🌙 Dark Mode</button>
        <h1>🎨 Pixel Art Drawer</h1>
        <div class="subtitle">Click and drag to draw! 🖌️</div>
        
        <div class="canvas-container">
            <canvas id="pixelCanvas" width="400" height="400"></canvas>
        </div>
        
        <div class="tools">
            <input type="color" id="colorPicker" class="color-picker" value="#667eea">
            <button class="tool-btn" id="drawBtn" onclick="setTool('draw')">✏️ Draw</button>
            <button class="tool-btn" id="eraseBtn" onclick="setTool('erase')">🧽 Erase</button>
            <button class="tool-btn" onclick="clearCanvas()">🗑️ Clear All</button>
            <button class="tool-btn" onclick="fillCanvas()">🎨 Fill All</button>
        </div>
        
        <div class="size-control">
            <span>🔘 Pixel Size:</span>
            <input type="range" id="pixelSize" min="4" max="20" value="10">
            <span id="sizeValue">10px</span>
        </div>
        
        <div>
            <button onclick="downloadImage()">💾 Download PNG</button>
        </div>
    </div>

    <script>
        const canvas = document.getElementById('pixelCanvas');
        const ctx = canvas.getContext('2d');
        let drawing = false;
        let currentTool = 'draw';
        let pixelSize = 10;
        
        let gridWidth = 40;  // 400 / 10
        let gridHeight = 40;
        
        // Initialize blank canvas
        function initCanvas() {
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            drawGrid();
        }
        
        function drawGrid() {
            ctx.strokeStyle = '#ddd';
            ctx.lineWidth = 0.5;
            for (let x = 0; x <= canvas.width; x += pixelSize) {
                ctx.beginPath();
                ctx.moveTo(x, 0);
                ctx.lineTo(x, canvas.height);
                ctx.stroke();
            }
            for (let y = 0; y <= canvas.height; y += pixelSize) {
                ctx.beginPath();
                ctx.moveTo(0, y);
                ctx.lineTo(canvas.width, y);
                ctx.stroke();
            }
        }
        
        function drawPixel(x, y, color) {
            const pixelX = Math.floor(x / pixelSize) * pixelSize;
            const pixelY = Math.floor(y / pixelSize) * pixelSize;
            
            ctx.fillStyle = color;
            ctx.fillRect(pixelX, pixelY, pixelSize - 0.5, pixelSize - 0.5);
            drawGrid();
        }
        
        function getPixelColor(x, y) {
            const pixelX = Math.floor(x / pixelSize) * pixelSize;
            const pixelY = Math.floor(y / pixelSize) * pixelSize;
            const imageData = ctx.getImageData(pixelX, pixelY, 1, 1);
            return `rgb(${imageData.data[0]}, ${imageData.data[1]}, ${imageData.data[2]})`;
        }
        
        function handleDraw(e) {
            if (!drawing) return;
            
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            
            let x, y;
            if (e.touches) {
                x = (e.touches[0].clientX - rect.left) * scaleX;
                y = (e.touches[0].clientY - rect.top) * scaleY;
            } else {
                x = (e.clientX - rect.left) * scaleX;
                y = (e.clientY - rect.top) * scaleY;
            }
            
            if (x >= 0 && x < canvas.width && y >= 0 && y < canvas.height) {
                const color = currentTool === 'draw' ? document.getElementById('colorPicker').value : 'white';
                drawPixel(x, y, color);
            }
        }
        
        function setTool(tool) {
            currentTool = tool;
            document.getElementById('drawBtn').classList.toggle('active', tool === 'draw');
            document.getElementById('eraseBtn').classList.toggle('active', tool === 'erase');
        }
        
        function clearCanvas() {
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            drawGrid();
        }
        
        function fillCanvas() {
            ctx.fillStyle = document.getElementById('colorPicker').value;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            drawGrid();
        }
        
        function downloadImage() {
            const link = document.createElement('a');
            link.download = 'pixel-art.png';
            link.href = canvas.toDataURL();
            link.click();
        }
        
        // Mouse events
        canvas.addEventListener('mousedown', (e) => {
            drawing = true;
            handleDraw(e);
        });
        canvas.addEventListener('mousemove', handleDraw);
        canvas.addEventListener('mouseup', () => drawing = false);
        canvas.addEventListener('mouseleave', () => drawing = false);
        
        // Touch events for mobile
        canvas.addEventListener('touchstart', (e) => {
            drawing = true;
            handleDraw(e);
            e.preventDefault();
        });
        canvas.addEventListener('touchmove', (e) => {
            handleDraw(e);
            e.preventDefault();
        });
        canvas.addEventListener('touchend', () => drawing = false);
        
        // Pixel size change
        const sizeSlider = document.getElementById('pixelSize');
        sizeSlider.addEventListener('input', (e) => {
            pixelSize = parseInt(e.target.value);
            document.getElementById('sizeValue').textContent = pixelSize + 'px';
            
            // Resize grid
            const oldImage = ctx.getImageData(0, 0, canvas.width, canvas.height);
            canvas.width = 400;
            canvas.height = 400;
            ctx.putImageData(oldImage, 0, 0);
            drawGrid();
        });
        
        function toggleDarkMode() {
            document.body.classList.toggle('dark-mode');
        }
        
        initCanvas();
        setTool('draw');
    </script>
</body>
</html>
